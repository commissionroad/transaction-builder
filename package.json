{
  "private": true,
  "type": "module",
  "name": "transaction-builder",
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*",
    "servers/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "bun run --cwd packages/transaction-builder-database db:migrate",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.6.3"
  }
}
