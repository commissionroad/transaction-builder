{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "PORT",
    "VITE_API_BASE_URL",
    "VITE_COMMISSIONROAD_API_BASE_URL",
    "VITE_MAINNET_RPC_URL",
    "VITE_BASE_RPC_URL",
    "VITE_SEPOLIA_RPC_URL",
    "VITE_ETHERSCAN_API_KEY",
    "VITE_WALLET_CONNECT_PROJECT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "test": {},
    "lint": {},
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
